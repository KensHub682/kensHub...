-- ==================== TOGGLE & DRAGGING ====================
local isVisible = true
local dragging = false
local dragStart
local startPos

local function playIntroAnimation()
    bg.Size = UDim2.new(0.3, 0, 0.3, 0)
    bg.Position = UDim2.new(0.35, 0, 0.35, 0)
    bg.BackgroundTransparency = 1
    TweenService:Create(bg, tweenInfo, {Size = UDim2.new(0.65, 0, 0.78, 0)}):Play()
    TweenService:Create(bg, tweenInfo, {Position = UDim2.new(0.175, 0, 0.11, 0)}):Play()
    TweenService:Create(bg, tweenInfo, {BackgroundTransparency = 0}):Play()
end

local function toggleGUI()
    isVisible = not isVisible
    if isVisible then
        bg.Visible = true
        toggleBtn.Parent = titleBar
        toggleBtn.Position = UDim2.new(1, -58, 0, 7)
        TweenService:Create(bg, tweenInfo, {BackgroundTransparency = 0}):Play()
        TweenService:Create(bg, tweenInfo, {Size = UDim2.new(0.65, 0, 0.78, 0)}):Play()
        TweenService:Create(bg, tweenInfo, {Position = UDim2.new(0.175, 0, 0.11, 0)}):Play()
    else
        local hideTween = TweenService:Create(bg, tweenInfo, {
            BackgroundTransparency = 1,
            Size = UDim2.new(0.3, 0, 0.3, 0),
            Position = UDim2.new(0.35, 0, 0.35, 0)
        })
        hideTween:Play()
        hideTween.Completed:Once(function()
            bg.Visible = false
        end)
        
        toggleBtn.Parent = screenGui
        TweenService:Create(toggleBtn, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {
            Position = UDim2.new(0.5, -23, 0.5, -23)
        }):Play()
    end
end

toggleBtn.MouseButton1Click:Connect(toggleGUI)

-- Dragging Code (unchanged)
local function startDragging(obj)
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
        end
    end)
end

startDragging(titleBar)
startDragging(toggleBtn)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local target = isVisible and bg or toggleBtn
        target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

playIntroAnimation()
