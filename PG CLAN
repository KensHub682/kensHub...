-- ==================== GREETINGS + TIME ====================
local function GetTimeInfo()
    local time = os.date("*t")
    local hour = time.hour
    local greeting = "Good Evening"
    
    if hour >= 5 and hour < 12 then
        greeting = "Good Morning"
    elseif hour >= 12 and hour < 17 then
        greeting = "Good Afternoon"
    end
    
    local dayName = os.date("%A")
    local currentTime = os.date("%I:%M %p")
    
    return greeting, dayName, currentTime
end

local Greeting, CurrentDay, CurrentTime = GetTimeInfo()

local function GetWelcomeText()
    local isNewPlayer = LocalPlayer.AccountAge < 7
    return isNewPlayer and "Welcome" or "Welcome Back"
end

