local function playWelcomeAnimation()
    local welcomeFrame = Instance.new("Frame")
    welcomeFrame.Size = UDim2.new(0, 0, 0, 0)
    welcomeFrame.Position = UDim2.new(0.5, 0, 0.38, 0)
    welcomeFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 22)
    welcomeFrame.BackgroundTransparency = 1
    welcomeFrame.BorderSizePixel = 0
    welcomeFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    welcomeFrame.Parent = screenGui

    Instance.new("UICorner", welcomeFrame).CornerRadius = UDim.new(0, 20)

    local welcomeText = Instance.new("TextLabel")
    welcomeText.Size = UDim2.new(1, -60, 1, -60)
    welcomeText.Position = UDim2.new(0, 30, 0, 30)
    welcomeText.BackgroundTransparency = 1
    welcomeText.Text = "Welcome, " .. player.DisplayName .. "\nto PG Clan Script"
    welcomeText.TextColor3 = Color3.fromRGB(0, 170, 255)
    welcomeText.TextScaled = true
    welcomeText.Font = Enum.Font.GothamBold
    welcomeText.TextTransparency = 1
    welcomeText.Parent = welcomeFrame

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 3
    stroke.Color = Color3.fromRGB(0, 200, 255)
    stroke.Parent = welcomeText

    local tweenIn = TweenService:Create(welcomeFrame, TweenInfo.new(0.65, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0.58, 0, 0.28, 0),
        BackgroundTransparency = 0.05
    })
    
    local textIn = TweenService:Create(welcomeText, TweenInfo.new(0.55, Enum.EasingStyle.Quint), {
        TextTransparency = 0
    })

    tweenIn:Play()
    task.wait(0.25)
    textIn:Play()

    task.delay(2.8, function()
        local tweenOut = TweenService:Create(welcomeFrame, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
            Size = UDim2.new(0.4, 0, 0.18, 0),
            BackgroundTransparency = 1
        })
        local textOut = TweenService:Create(welcomeText, TweenInfo.new(0.5), {TextTransparency = 1})
        
        tweenOut:Play()
        textOut:Play()
        
        tweenOut.Completed:Connect(function()
            welcomeFrame:Destroy()
        end)
    end)
end

